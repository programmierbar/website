# Nuxt reads .env (NOT .env.local) in development.
#
# Option 1: Pull env vars from Vercel, then override CMS URL:
#   npx vercel env pull .env
#   Then set DIRECTUS_CMS_URL=http://localhost:8055 in .env
#
# Option 2: Copy this file and edit:
#   cp .env.example .env
#
DIRECTUS_CMS_URL=http://localhost:8055
WEBSITE_URL=http://localhost:3000
NUXT_ENV=development

# Stripe (for ticket purchase testing)
# Get test keys from https://dashboard.stripe.com/test/apikeys
NUXT_STRIPE_SECRET_KEY=sk_test_...
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret — provided by `stripe listen` (see below)
NUXT_STRIPE_WEBHOOK_SECRET=whsec_...
#
# Local webhook forwarding requires the Stripe CLI:
#   brew install stripe/stripe-cli/stripe
#   stripe login
#   stripe listen --forward-to localhost:3000/api/tickets/webhook
#
# Copy the whsec_... secret from the output into NUXT_STRIPE_WEBHOOK_SECRET,
# then restart Nuxt. Use test card 4242 4242 4242 4242 (any future exp, any CVC).
