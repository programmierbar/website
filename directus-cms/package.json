{
  "name": "directus-cms",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "setup": "./setup.sh",
    "setup:reset": "./setup.sh --reset",
    "migrate:db": "directus database migrate:latest",
    "postbootstrap": "npm run migrate:db",
    "bootstrap": "directus bootstrap",
    "prestart": "npm run migrate:db",
    "start": "directus start",
    "snapshot-schema": "directus schema snapshot ./schema.json --format json",
    "apply-schema": "directus schema apply ./schema.json"
  },
  "dependencies": {
    "@directus/sdk": "^21.3.0",
    "directus": "^11.17.4",
    "dotenv": "^17.2.3",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "prettier": "^2.5.1"
  },
  "overrides": {
    "isolated-vm": "^6.0.2",
    "@aws-sdk/client-s3": "latest",
    "@aws-sdk/client-sesv2": "latest",
    "@aws-sdk/client-sso": "latest",
    "@aws-sdk/core": "latest",
    "@aws-sdk/credential-provider-env": "latest",
    "@aws-sdk/credential-provider-http": "latest",
    "@aws-sdk/credential-provider-ini": "latest",
    "@aws-sdk/credential-provider-node": "latest",
    "@aws-sdk/credential-provider-process": "latest",
    "@aws-sdk/credential-provider-sso": "latest",
