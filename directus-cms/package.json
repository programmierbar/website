    "cacache": "^20.0.4",
    "make-fetch-happen": "^15.0.5",
    "node-gyp": "^12.3.0",
    "http-proxy-agent": "^7.0.2",
    "retry-request": "^8.0.2",
    "teeny-request": "^10.1.2",
    "@tootallnate/once": "^3.0.1",
    "tar": "^7.5.14",
